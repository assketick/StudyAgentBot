    {
      "parameters": {
        "jsCode": "const newMessageData = $('Save message to DB').item.json;\nconst history = $('Select message history from current chat').all().map(item => item.json);\n\nconst historyText = history\n  .map((msg, i) => `${i + 1}) ${msg.sender_first_name}: ${msg.text}`)\n  .join('\\n');\n\n\nreturn [{\n  json: {\n    context: historyText,\n    new_message: newMessageData\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
