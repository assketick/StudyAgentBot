    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=NEW MESSAGE (extract deadlines only from this):\n{{ $json.new_message.text }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "=Твоя задача определить, есть ли в этом сообщении дедлайн, задача или отмена чего-то? \nCONTEXT (предыдущие сообщения). Если среди них уже был дедлайн/задача, который пришел в текущем сообщении, то игнорируй его. Дубликаты запрещены:\n{{ $json.context }}\n\n\nВерни JSON со следующей схемой:\n{\n  \"type\": \"object\",\n  \"properties\": {\n    \"action\": {\n      \"type\": \"string\",\n      \"required\": true,\n      \"description\": \"What to do: 'create', 'update', 'delete', or 'none' if no deadline found\"\n    },\n    \"title\": {\n      \"type\": [\"string\", \"null\"],\n      \"required\": false,\n      \"description\": \"Short title of the deadline\"\n    },\n    \"subject\": {\n      \"type\": [\"string\", \"null\"],\n      \"required\": false,\n      \"description\": \"Subject or category\"\n    },\n    \"due_at\": {\n      \"type\": [\"string\", \"null\"],\n      \"required\": false,\n      \"description\": \"Datetime in ISO 8601 format\"\n    },\n    \"source_text\": {\n      \"type\": [\"string\", \"null\"],\n      \"required\": false,\n      \"description\": \"Original message text\"\n    }\n  }\n}"
        }
      },
